# ===========================================================================
# AI Data Hub 서버 — 배포용 환경 변수 예시
#
# 사용:
#   cp .env.example .env
#   (필요 시 비밀번호/포트/임베더 수정)
# ===========================================================================

# -----------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------
# 컨테이너 내부 DB 비밀번호 (반드시 변경 권장).
POSTGRES_PASSWORD=aidh_change_me
# 호스트에 노출할 PG 포트. 다른 PG 와 충돌 시 5433 등으로 변경.
POSTGRES_PORT=5432

# -----------------------------------------------------------------
# API 서버
# -----------------------------------------------------------------
API_PORT=8000
LOG_LEVEL=INFO
# json | text  (json 권장, JSON 라인 로그)
LOG_FORMAT=json

# -----------------------------------------------------------------
# 인증
# -----------------------------------------------------------------
# true 면 모든 요청에 X-API-Key 헤더 필수. false 면 익명 허용.
AUTH_REQUIRED=false
# 부트스트랩 키 (운영 키 발급용 마스터). 빈 문자열이면 비활성.
# 운영 시: 강한 랜덤 문자열로 변경 후 사용 끝나면 빈 값으로 되돌릴 것.
BOOTSTRAP_API_KEY=

# -----------------------------------------------------------------
# 임베더 (시맨틱 검색)
#   hash   — 외부 의존성 X. 결정론. 의미 신호 약함 (smoke/CI 용).
#   openai — text-embedding-3-small (dim=384). OPENAI_API_KEY 필요.
# -----------------------------------------------------------------
EMBEDDING_PROVIDER=hash
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------
# 빌드 식별자 (옵션) — /api/system/health 의 build 필드에 노출.
# -----------------------------------------------------------------
BUILD_SHA=deploy
