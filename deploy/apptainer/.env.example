# AI Data Hub — Apptainer 환경 변수 (.env.example)
# 새 머신:
#   * git clone 경로: bash setup.sh   (또는 install_all.sh — 서버만)
#   * bundle 경로:    bash install.sh (자동으로 HOST_IP / .env 처리)
#
# ⚠ Placeholders (install.sh 가 자동 치환):
#   HOST_IP         — 현재 서버의 IP. install.sh 가 ifconfig.me 또는 hostname -I 로 감지 후 sed 치환.
#   CHANGE_ME       — 비밀번호. 그대로 두면 경고만 출력 — 운영 전 수동 회전 필요.
# ============================================================================

# ── 앱 식별자 (같은 서버에 여러 AIDH 공존 시) ─────────────────────────
# instance 이름 prefix 가 됨 (예: APP_NAME=aidh → aidh_postgres).
# 다른 앱 운영 시 APP_NAME 만 바꾸면 끝 (다른 모든 자원 자동 분리).
APP_NAME=aidh

# ── 호스트 IP (CORS / 외부 접속 안내용) ────────────────────────────
# install.sh 가 HOST_IP literal 을 감지된 IP 로 치환.
# 수동 수정 시: 0.0.0.0 또는 사내망 IP 입력.
HOST_IP=HOST_IP


# ── 프록시 (사내망 등) ─────────────────────────────────────────────
# 우선순위:
#   1) HTTPS_PROXY/HTTP_PROXY    (.env 에서 명시 — 최우선)
#   2) BUILD_PROXY_HTTPS/HTTP    (.env 에서 명시)
#   3) DEFAULT_FALLBACK_PROXY    (_common.sh 의 하드코딩 사내 표준)
#
# 어떤 단계에서든 결정된 프록시는 apt/pip/npm/apptainer/huggingface 모두에 적용됨.
# 즉 .env 에 한 줄도 안 적어도 사내망에서는 자동 동작 — DEFAULT_FALLBACK_PROXY 가
# (http://168.219.61.252:8080) 적용된다.
#
# 외부 환경(사내망 밖)에서 프록시 완전 비활성:
#   BUILD_PROXY_HTTPS=off
#
# 다른 프록시를 쓰고 싶으면 HTTPS_PROXY 또는 BUILD_PROXY_HTTPS 에 그 값 직접 입력.
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=

# 사내 표준 프록시 (덮어쓰기 가능). 비워두면 _common.sh 의 하드코딩 폴백 적용.
# 외부 환경에서 비활성하려면: BUILD_PROXY_HTTPS=off
BUILD_PROXY_HTTPS=http://168.219.61.252:8080
BUILD_PROXY_HTTP=http://168.219.61.252:8080

# ── Apptainer 네트워크 (Issue #3 — cross-host 변동성) ──────────────
# 일부 Apptainer 빌드는 instance 를 자체 netns 에 띄움 → host 의 127.0.0.1 로
# API 가 postgres 못 닿을 수 있음. 기본 0 (대부분 환경에서 host network 공유).
# host CNI conflist 가 /etc/apptainer/network/ 에 있는 환경에서만 1 로:
AIDH_APPT_HOST_NET=0

# ── CORS (운영 환경 IP 추가) ─────────────────────────────────────
# 현재 main.py 는 dev 편의상 ``allow_origins=["*"]``. 외부 노출 시 좁힐 것.
# 예시 (운영자가 main.py 수정 또는 .env-driven 으로 변경할 때 참고):
# CORS_ORIGINS=http://localhost:5173,http://10.252.39.181:8001

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=aidh
POSTGRES_PASSWORD=aidh_change_me
POSTGRES_DB=aidh
POSTGRES_HOST=127.0.0.1
# 호스트가 이미 5432 점유 중이면 5435 같은 다른 포트로 변경.
POSTGRES_PORT=5435
# INST_POSTGRES 는 _common.sh 가 APP_NAME 으로부터 자동 생성 (aidh → aidh_postgres).
# 수동 override 가 필요한 특수 경우만 아래 주석 풀기:
# INST_POSTGRES=aidh_postgres

# ── EXTERNAL PG 모드 (같은 서버의 다른 프로젝트 PG 공유) ────────────
# 0 (default): 자체 apptainer instance 띄움
# 1         : 외부 PG 인스턴스 안에 aidh DB 만 생성·연결. 인스턴스 미기동.
#
# 예시 — MXWhitePaper 의 mxwp_postgres (port 5532) 공유:
#   EXTERNAL_POSTGRES=1
#   POSTGRES_HOST=127.0.0.1
#   POSTGRES_PORT=5532
#   EXTERNAL_PG_INSTANCE=mxwp_postgres
#   EXTERNAL_PG_SUPERUSER=mxwp
#   EXTERNAL_PG_SUPERUSER_DB=mxwp
# 그 다음 한 번만:
#   bash deploy/apptainer/setup-shared-pg.sh
# 이후 bash deploy/apptainer/start_api.sh 만 실행. PG 자체는 안 띄움.
EXTERNAL_POSTGRES=0
EXTERNAL_PG_INSTANCE=mxwp_postgres
EXTERNAL_PG_SUPERUSER=mxwp
EXTERNAL_PG_SUPERUSER_DB=mxwp

# ── API 서버 (native venv) ─────────────────────────────────────────
# 호스트가 8000 점유 중이면 8001 등으로 변경.
API_PORT=8001
API_HOST=0.0.0.0
AUTH_REQUIRED=false
BOOTSTRAP_API_KEY=
LOG_LEVEL=INFO
LOG_FORMAT=json

# 임베더 (시맨틱 검색):
#   hash      — smoke/CI 폴백. 결정론, 의미 신호 약함. 외부 의존성 없음. (dim=384)
#   e5_small  — multilingual-e5-small. 한국어 우수, CPU OK, 모델 ~118MB. (dim=384)
#   e5_base   — multilingual-e5-base.  한국어 더 좋음, 모델 ~278MB.       (dim=768)
#   e5_large  — multilingual-e5-large. 가장 정확, 모델 ~560MB.           (dim=1024)
#   openai    — text-embedding-3-small (dim=384). OPENAI_API_KEY 필요.
#
# EMBEDDING_DIM 은 EMBEDDING_PROVIDER 와 정합해야 한다 — start_api.sh 가
# provider 별로 자동 매핑(small=384/base=768/large=1024)하므로 보통 손대지 않는다.
# 직접 설정한 경우 alembic 0013 의 vector(NNN) 컬럼과도 일치해야 한다.
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=384
AUTO_EMBED_ON_INSERT=true

# /api/ask LLM 모드 (선택). 사내 NL 해석을 OpenAI 호환 백엔드로 라우팅할 때만 사용.
# Cline/Qwen 등 클라이언트 LLM 을 쓰면 본 변수는 비워둔다 — keyword fallback 으로 동작.
#   OPENAI_API_KEY    : 정품 OpenAI 또는 호환 백엔드의 인증 토큰 (없으면 비활성)
#   OPENAI_BASE_URL   : 호환 백엔드 endpoint (예: http://qwen.corp.local:8000/v1).
#                       비워두면 정품 OpenAI (api.openai.com).
#   OPENAI_ASK_MODEL  : 모델 ID (default gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ASK_MODEL=
BUILD_SHA=apptainer-deploy

# DATABASE_URL 은 위 변수를 조합해 start_api.sh 가 자동 생성한다.

# ── Drive 동기화 (setup-drive-sync.sh 가 자동 작성) ──────────────────
# AIDH_DRIVE_REMOTE=AidhDrive:AIDataHub/db-dumps   # rclone remote:folder
# AIDH_DRIVE_RETAIN=5                              # Drive 보존 개수

# ── Behind the HWAX portal (sub-path serving) ───────────────────────────────
# Empty = standalone. Set to the public prefix to run UNDER the portal, which reverse-proxies
# https://hwax.sec.samsung.net/ai-data-hub/ → this service (prefix stripped). Loaded+exported by
# _common.sh → start_api.sh passes it to uvicorn as --root-path (docs/openapi URLs carry the prefix;
# the dashboard derives the prefix itself and "/" redirects browsers to the dashboard).
AIDH_ROOT_PATH=/ai-data-hub

# ── sync SSRF 가드 예외 ──────────────────────────────────────────────────────
# sync 대상 (SignalForge/MXWP 등) 이 같은 호스트의 내부 서비스 (비표준 포트/사설 IP)
# 면 true. 외부 인터넷 소스만 쓰는 배포에서는 설정하지 말 것 (SSRF 방어 유지).
# 인앱 스케줄러 (main.py) 가 자동 sync 를 돌릴 때도 이 가드를 통과해야 한다.
AIDH_SYNC_ALLOW_INTERNAL=true

# ── 인앱 스케줄러 (v0.14) ────────────────────────────────────────────────────
# sync_sources.schedule_cron 자동 실행 + 30분 주기 embed sweep. off 로 끄면
# 외부 cron 운영으로 회귀 (POST /api/sync/sources/{id}/run).
# AIDH_SCHEDULER=off
# AIDH_EMBED_SWEEP_MIN=30
