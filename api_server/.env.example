# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_data

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO

# Authentication — set true to require X-API-Key on all routes.
# AUTH_REQUIRED=false
# Bootstrap key (first issuance / key management). Leave empty to disable.
# BOOTSTRAP_API_KEY=

# Upload limits
# MAX_UPLOAD_MB=50

# CORS — vscode-webview://* 는 항상 허용된다. 운영용 추가 오리진을 콤마로 나열.
# 예: EXTRA_ALLOWED_ORIGINS=https://datahub.example.com,https://staging.x.io
# EXTRA_ALLOWED_ORIGINS=

# Build identifier — /api/system/health 응답의 build 필드.
# BUILD_SHA=dev
