{
  "name": "mxwp",
  "description": "MXWhitePaper 위키 (DocumentJSON v1.0) — published 문서를 AX Hub 로 미러",
  "base_url": "http://mxwp-api:8000",
  "api_key": "${MXWP_INTERNAL_KEY}",
  "auth_header": "X-API-Key",
  "list_endpoint": "/api/v1/documents",
  "list_method": "GET",
  "detail_endpoint": "/api/v1/documents/{slug}",
  "cursor_param": "offset",
  "since_param": "_unsupported_updated_since",
  "limit_param": "limit",
  "page_size": 100,
  "_note": "Sprint 3 limit/offset 페이지네이션. cursor_param 을 offset 으로 사용 (응답 meta.next_offset → 다음 호출). updated_since 는 server-side 미지원 — client-side 필터로 동작. 사업부 화이트페이퍼 수천 건도 OK.",
  "max_rps": 2.0,
  "retry_max": 3,
  "retry_backoff_sec": 2.0,
  "trust_pii_masked": false,
  "schedule_cron": "*/30 * * * *",
  "enabled": true,
  "mapping_rules": {
    "id_field": "document_id",
    "title_field": "title",
    "body_field": "body_text",
    "summary_field": "summary",
    "tags_fields": ["tags", "authors", "status"],
    "subject_keywords_fields": ["keywords"],
    "valid_from_field": "created_at",
    "year_field": "created_at",
    "data_type": "DOC",
    "team": "MX",
    "group": "WP",
    "doc_type": "whitepaper",
    "agents": ["mx-whitepaper-analyst"],
    "classification": "internal",
    "language": "ko",
    "list_filter": { "status": "published" },
    "attachment_mode": "url_ref",
    "attachment_url_template": "{base_url}/api/v1/files/{image_id}",
    "sections_field": "content.sections",
    "external_source": "mxwp"
  }
}
