{
  "name": "ai-data-hub-uploader",
  "displayName": "AI Data Hub Uploader",
  "description": "Upload, bundle and search records in your AI Data Hub backend — drag-drop original files (.docx/.pdf/.pptx/.md/.xlsx), or pre-converted JSON+resources zip bundles, plus semantic / FTS / tag search.",
  "version": "0.4.0",
  "publisher": "squall321",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/squall321/AIDataHubExtension.git"
  },
  "bugs": {
    "url": "https://github.com/squall321/AIDataHubExtension/issues"
  },
  "homepage": "https://github.com/squall321/AIDataHubExtension#readme",
  "keywords": [
    "ai",
    "rag",
    "uploader",
    "data-hub",
    "fastapi",
    "drag-and-drop"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aidh.openUploader",
        "title": "AI Data Hub: Open Uploader",
        "category": "AI Data Hub"
      },
      {
        "command": "aidh.openSettings",
        "title": "AI Data Hub: Settings",
        "category": "AI Data Hub"
      },
      {
        "command": "aidh.resetConnection",
        "title": "AI Data Hub: Reset Connection",
        "category": "AI Data Hub"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
